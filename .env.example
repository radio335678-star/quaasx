# generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# AI² Rust Env (Modal ai2-rust-env) — chat via POST /exec → agent_run.py
# No OpenRouter key on Vercel (key lives in Modal secret openrouter-key)
# Live:  https://quaasx--ai2-rust-env-rustenvgateway-web.modal.run
AI2_BACKEND_URL=https://quaasx--ai2-rust-env-rustenvgateway-web.modal.run

# Web-X local search engine (Flask on your laptop) — proxied via /api/webx/*
# Local dev: http://127.0.0.1:5000 (default). Production: Cloudflare/ngrok tunnel HTTPS URL.
WEBX_BACKEND_URL=http://127.0.0.1:5000
# Same secret as WEBX_API_SECRET in C:\scrapling\agentic_scraper\.env (server-only, never expose to browser)
WEBX_API_SECRET=

# Optional — Postgres / Blob / AI Gateway (not required for public AI² chat)
AI_GATEWAY_API_KEY=
BLOB_READ_WRITE_TOKEN=
POSTGRES_URL=
REDIS_URL=
