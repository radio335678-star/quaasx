# generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# AI² Rust Env (Modal ai2-rust-env) — chat via POST /exec → agent_run.py
# No OpenRouter key on Vercel (key lives in Modal secret openrouter-key)
# Live:  https://quaasx--ai2-rust-env-rustenvgateway-web.modal.run
AI2_BACKEND_URL=https://quaasx--ai2-rust-env-rustenvgateway-web.modal.run

# Private bridge secret for Flash/Pro → Kamatera Linga agent
# Must match Kamatera /opt/webx/.env AI2_WEBX_BRIDGE_SECRET (never NEXT_PUBLIC_*)
AI2_WEBX_BRIDGE_SECRET=

# Public site URLs (same Vercel project — two domains)
NEXT_PUBLIC_AI2_URL=https://ai2.quaasx108.com
NEXT_PUBLIC_WEBX_URL=https://webx.quaasx108.com
WEBX_PUBLIC_HOST=webx.quaasx108.com

# Web-X API — Kamatera always-on (api subdomain)
WEBX_BACKEND_URL=https://api.webx.quaasx108.com
# Legacy Modal fallback if Kamatera unset: https://quaasx--ai2-web-x-webxgateway-web.modal.run
WEBX_API_SECRET=

# Server-only benchmark validator pass-key (never NEXT_PUBLIC_*)
AI2_VALIDATOR_PASSKEY=

# Optional — Postgres / Blob / AI Gateway (not required for public AI² chat)
AI_GATEWAY_API_KEY=
BLOB_READ_WRITE_TOKEN=
POSTGRES_URL=
REDIS_URL=
